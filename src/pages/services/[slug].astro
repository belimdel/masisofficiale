---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { services } from "../../data/services";

export async function getStaticPaths() {
  return services.map((service) => ({
    params: {
      slug: service.slug,
    },
    props: {
      service,
    },
  }));
}

const { service } = Astro.props;
---

<BaseLayout
  titre={service.seoTitle}
  description={service.seoDescription}
>

<section class="relative h-[70vh] overflow-hidden">

  <img
    src={service.image}
    alt={service.title}
    class="absolute inset-0 h-full w-full object-cover"
  />

  <div class="absolute inset-0 bg-black/70"></div>

  <div
    class="relative z-10 flex h-full items-center justify-center text-center px-6"
  >
    <div
      class="max-w-4xl animate-fade-up"
    >

      <h1
        class="text-5xl md:text-7xl font-black uppercase text-white mb-6"
      >
        {service.title}
      </h1>

      <p
        class="text-xl text-gray-200 max-w-3xl mx-auto"
      >
        {service.intro}
      </p>
    </div>
  </div>

</section>

<section class="py-24 bg-white">

  <div class="max-w-6xl mx-auto px-6">

    <div class="grid lg:grid-cols-2 gap-16">

      <div>

        <h2
          class="text-4xl font-black mb-8"
        >
          Votre spécialiste en Gironde
        </h2>

        <div
          class="space-y-6 text-lg text-gray-700 leading-relaxed"
        >
          <p>{service.content.section1}</p>
          <p>{service.content.section2}</p>
          <p>{service.content.section3}</p>
        </div>

      </div>

      <div>

        <div
          class="bg-gray-50 rounded-2xl p-8 shadow-sm"
        >

          <h3
            class="text-2xl font-bold mb-6"
          >
            Nos prestations
          </h3>

          <div class="space-y-4">

            {service.benefits.map((benefit) => (

              <div
                class="flex items-center gap-3 hover:translate-x-2 transition"
              >
                <div
                  class="h-3 w-3 rounded-full bg-green-600"
                ></div>

                <span>{benefit}</span>
              </div>

            ))}

          </div>

        </div>

      </div>

    </div>

  </div>

</section>

<section
  class="py-24 bg-gray-900 text-white"
>

  <div class="max-w-6xl mx-auto px-6">

    <h2
      class="text-4xl font-black text-center mb-16"
    >
      Notre méthode d'intervention
    </h2>

    <div
      class="grid md:grid-cols-5 gap-8"
    >

      {service.process.map((step, index) => (

        <div
          class="text-center group"
        >

          <div
            class="w-16 h-16 mx-auto rounded-full bg-green-600 flex items-center justify-center text-2xl font-bold mb-4 group-hover:scale-110 transition"
          >
            {index + 1}
          </div>

          <p>{step}</p>

        </div>

      ))}

    </div>

  </div>

</section>

<section
  class="py-24 bg-white"
>

  <div class="max-w-4xl mx-auto px-6">

    <h2
      class="text-4xl font-black text-center mb-12"
    >
      Questions fréquentes
    </h2>

    <div class="space-y-6">

      {service.faq.map((item) => (

        <div
          class="border border-gray-200 rounded-xl p-6 hover:shadow-lg transition"
        >

          <h3
            class="font-bold text-xl mb-3"
          >
            {item.question}
          </h3>

          <p
            class="text-gray-600"
          >
            {item.answer}
          </p>

        </div>

      ))}

    </div>

  </div>

</section>

<section
  class="py-24 bg-gray-950 text-center text-white"
>

  <div
    class="max-w-4xl mx-auto px-6"
  >

    <h2
      class="text-5xl font-black mb-6"
    >
      Besoin d'un devis gratuit ?
    </h2>

    <p
      class="text-xl text-gray-300 mb-8"
    >
      Intervention rapide sur Bordeaux et toute la Gironde.
    </p>

    <a
      href="/contact"
      class="inline-block bg-green-600 hover:bg-green-700 px-8 py-4 rounded-lg font-bold transition hover:scale-105"
    >
      Demander un devis
    </a>

  </div>

</section>

</BaseLayout>