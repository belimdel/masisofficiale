---
const temoignages = [
  {
    nom: "Sophie M.",
    lieu: "Bordeaux",
    note: 5,
    texte: "Masis a complètement transformé notre jardin. Travail soigné, délais respectés et équipe très professionnelle. Je recommande sans hésiter.",
    service: "Création de jardin",
    initiale: "S"
  },
  {
    nom: "Laurent B.",
    lieu: "Mérignac",
    note: 5,
    texte: "Intervention rapide pour l'élagage de nos arbres. Très bon rapport qualité-prix, chantier propre laissé à la fin. On refera appel à eux.",
    service: "Élagage",
    initiale: "L"
  },
  {
    nom: "Isabelle & Marc T.",
    lieu: "Arcachon",
    note: 5,
    texte: "Installation d'un système d'arrosage automatique nickel. Masis a pris le temps d'expliquer le fonctionnement et le suivi est top.",
    service: "Arrosage automatique",
    initiale: "I"
  },
];
---

<section class="py-24 bg-gray-900" aria-labelledby="temoignages-titre">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div data-reveal class="text-center mb-16">
      <span class="text-green-500 font-semibold uppercase tracking-widest text-sm">Ils nous font confiance</span>
      <h2 id="temoignages-titre" class="mt-3 text-4xl font-black text-white uppercase">
        Avis clients
      </h2>
      <div class="w-14 h-1 bg-green-600 mx-auto mt-5"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {temoignages.map((t, index) => (
        <article
          data-reveal
          data-reveal-delay={String(index + 1)}
          class="group bg-gray-800 hover:bg-gray-750 p-8 flex flex-col gap-5 border border-gray-700 hover:border-green-800 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-black/40"
        >
          <!-- Étoiles -->
          <div class="flex gap-1" aria-label={`Note : ${t.note} sur 5`}>
            {Array.from({ length: t.note }).map(() => (
              <span class="text-green-400 text-lg leading-none" aria-hidden="true">★</span>
            ))}
          </div>

          <!-- Guillemet décoratif -->
          <svg class="w-8 h-8 text-green-600/30" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>

          <!-- Texte -->
          <blockquote class="text-gray-300 leading-relaxed flex-1 text-sm md:text-base">
            {t.texte}
          </blockquote>

          <!-- Auteur -->
          <footer class="border-t border-gray-700 pt-5 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-green-600 flex items-center justify-center text-white font-bold text-sm shrink-0">
              {t.initiale}
            </div>
            <div>
              <p class="text-white font-bold text-sm">{t.nom}</p>
              <p class="text-gray-400 text-xs">{t.lieu} · {t.service}</p>
            </div>
          </footer>
        </article>
      ))}
    </div>

    <!-- Lien Google -->
    <p data-reveal class="text-center mt-12 text-gray-400 text-sm">
      Plus de 50 avis vérifiés sur
      <a href="#" class="text-green-400 font-semibold hover:underline hover:text-green-300 transition-colors" target="_blank" rel="noopener noreferrer">
        Google Business ↗
      </a>
    </p>

  </div>
</section>
