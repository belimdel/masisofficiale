---
import { Image } from 'astro:assets';
import logo from '../assets/logo/favicon.svg';

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/services', label: 'Services' },
  { href: '/realisations', label: 'Réalisations' },
  { href: '/zone-intervention', label: "Zone d'intervention" },
  { href: '/contact', label: 'Contact' },
];

const path = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-300 bg-white/95 backdrop-blur-sm border-b border-gray-100 shadow-sm">
  <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">

    <a href="/" aria-label="Masis Paysagiste — Accueil" class="shrink-0">
      <Image src={logo} alt="Masis Paysagiste" height={60} width={60} class="object-contain" />
    </a>

    <nav class="hidden md:flex items-center gap-8" aria-label="Navigation principale">
      {navLinks.map((link) => {
        const isActive = link.href === '/'
          ? path === '/'
          : path.startsWith(link.href);
        return (
          <a
            href={link.href}
            class:list={[
              "relative font-semibold uppercase tracking-wide text-sm transition-colors duration-200 py-1",
              isActive
                ? "text-green-600 after:absolute after:bottom-0 after:left-0 after:right-0 after:h-0.5 after:bg-green-600 after:rounded-full"
                : "text-gray-700 hover:text-green-600"
            ]}
            aria-current={isActive ? "page" : undefined}
          >
            {link.label}
          </a>
        );
      })}
    </nav>

    <a
      href="/contact"
      class="hidden md:inline-flex items-center gap-2 bg-green-600 text-white font-bold px-6 py-3 uppercase tracking-wide text-sm hover:bg-green-700 transition-all duration-200 hover:scale-105"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
      </svg>
      Devis gratuit
    </a>

    <!-- Bouton burger -->
    <button
      id="burger"
      class="md:hidden flex flex-col justify-center gap-1.5 w-10 h-10 cursor-pointer"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span id="burger-line-1" class="block w-6 h-0.5 bg-gray-900 transition-all duration-300 origin-center"></span>
      <span id="burger-line-2" class="block w-6 h-0.5 bg-gray-900 transition-all duration-300"></span>
      <span id="burger-line-3" class="block w-6 h-0.5 bg-gray-900 transition-all duration-300 origin-center"></span>
    </button>

  </div>

  <!-- Menu mobile -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden bg-white border-t border-gray-100"
    aria-hidden="true"
  >
    <nav class="px-6 py-4 flex flex-col gap-1" aria-label="Navigation mobile">
      {navLinks.map((link) => {
        const isActive = link.href === '/'
          ? path === '/'
          : path.startsWith(link.href);
        return (
          <a
            href={link.href}
            class:list={[
              "font-semibold uppercase tracking-wide text-sm py-3 border-b border-gray-50 transition-colors duration-200",
              isActive ? "text-green-600" : "text-gray-700 hover:text-green-600"
            ]}
          >
            {link.label}
          </a>
        );
      })}
      <a
        href="/contact"
        class="mt-3 bg-green-600 text-white font-bold px-6 py-3 uppercase tracking-wide text-sm text-center hover:bg-green-700 transition-colors"
      >
        Devis gratuit
      </a>
    </nav>
  </div>
</header>

<script>
  import { gsap } from 'gsap';

  const burger = document.getElementById('burger') as HTMLElement | null;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement | null;
  const header = document.getElementById('site-header') as HTMLElement | null;
  const line1 = document.getElementById('burger-line-1');
  const line2 = document.getElementById('burger-line-2');
  const line3 = document.getElementById('burger-line-3');
  const navItems = mobileMenu?.querySelectorAll<HTMLElement>('a') ?? [];
  let isOpen = false;

  // État initial du menu
  if (mobileMenu) {
    gsap.set(mobileMenu, { height: 0, overflow: 'hidden' });
    gsap.set(navItems, { opacity: 0, x: -12 });
  }

  function openMenu() {
    if (!mobileMenu || !burger) return;
    isOpen = true;
    burger.setAttribute('aria-expanded', 'true');
    mobileMenu.setAttribute('aria-hidden', 'false');
    mobileMenu.style.display = 'block';

    gsap.to(mobileMenu, { height: 'auto', duration: 0.35, ease: 'power2.out' });
    gsap.to(navItems, { opacity: 1, x: 0, duration: 0.25, stagger: 0.05, ease: 'power2.out', delay: 0.12 });

    if (line1) gsap.to(line1, { rotate: 45, y: 8, duration: 0.3, ease: 'power2.out' });
    if (line2) gsap.to(line2, { opacity: 0, scaleX: 0, duration: 0.2 });
    if (line3) gsap.to(line3, { rotate: -45, y: -8, duration: 0.3, ease: 'power2.out' });
  }

  function closeMenu() {
    if (!mobileMenu || !burger) return;
    isOpen = false;
    burger.setAttribute('aria-expanded', 'false');
    mobileMenu.setAttribute('aria-hidden', 'true');

    gsap.to(navItems, { opacity: 0, x: -8, duration: 0.15, stagger: 0.02 });
    gsap.to(mobileMenu, { height: 0, duration: 0.3, ease: 'power2.in', delay: 0.08 });

    if (line1) gsap.to(line1, { rotate: 0, y: 0, duration: 0.3, ease: 'power2.out' });
    if (line2) gsap.to(line2, { opacity: 1, scaleX: 1, duration: 0.2, delay: 0.1 });
    if (line3) gsap.to(line3, { rotate: 0, y: 0, duration: 0.3, ease: 'power2.out' });
  }

  burger?.addEventListener('click', () => { isOpen ? closeMenu() : openMenu(); });

  // Fermer au clic sur un lien nav
  navItems.forEach((item) => {
    item.addEventListener('click', () => { if (isOpen) closeMenu(); });
  });

  // Fermer au clic ailleurs
  document.addEventListener('click', (e) => {
    if (isOpen && !burger?.contains(e.target as Node) && !mobileMenu?.contains(e.target as Node)) {
      closeMenu();
    }
  });

  // Ombre renforcée au scroll
  if (header) {
    window.addEventListener('scroll', () => {
      header.classList.toggle('scrolled', window.scrollY > 20);
    }, { passive: true });
  }
</script>

<style>
  #site-header.scrolled {
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.1);
  }
</style>