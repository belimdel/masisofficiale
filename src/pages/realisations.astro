---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';

import apres1 from '../assets/images/realisation-1.webp';
import apres2 from '../assets/images/realisation-2.jpg';
import apres3 from '../assets/images/realisation-3.jpg';
import apres4 from '../assets/images/realisation-4.jpg';
import apres5 from '../assets/images/realisation-5.jpg';
import apres6 from '../assets/images/realisation-6.webp';

import avant1 from '../assets/images/realisation-1-avant.jpg';
import avant2 from '../assets/images/realisation-2-avant.jpg';
import avant3 from '../assets/images/realisation-3-avant.jpg';
import avant4 from '../assets/images/realisation-4-avant.jpg';
import avant5 from '../assets/images/realisation-5-avant.jpg';
import avant6 from '../assets/images/realisation-6-avant.jpg';

const titre = "Réalisations Paysagiste en Gironde | Masis Paysagiste";
const description = "Découvrez les réalisations de Masis Paysagiste en Gironde : créations de jardins, terrasses, élagage, arrosage automatique. Avant/après de nos projets.";

const realisations = [
  { avant: avant1, apres: apres1, titre: "Création de jardin contemporain", lieu: "Bordeaux", categorie: "Création" },
  { avant: avant2, apres: apres2, titre: "Terrasse bois et aménagement", lieu: "Mérignac", categorie: "Terrasse" },
  { avant: avant3, apres: apres3, titre: "Entretien parc résidentiel", lieu: "Pessac", categorie: "Entretien" },
  { avant: avant4, apres: apres4, titre: "Élagage et mise en forme", lieu: "Arcachon", categorie: "Élagage" },
  { avant: avant5, apres: apres5, titre: "Arrosage automatique", lieu: "Talence", categorie: "Arrosage" },
  { avant: avant6, apres: apres6, titre: "Clôture et portail sur-mesure", lieu: "Libourne", categorie: "Clôture" },
];

const categories = ["Tous", ...new Set(realisations.map(r => r.categorie))];
---

<BaseLayout titre={titre} description={description}>

  <!-- Hero -->
  <section class="relative h-64 md:h-80 flex items-center justify-center overflow-hidden bg-gray-900">
    <div class="absolute inset-0 bg-cover bg-center opacity-25" style="background-image: url('/images/hero-bg.jpg');"></div>
    <div class="relative z-10 text-center px-6">
      <span class="text-green-400 font-bold uppercase tracking-widest text-sm">Nos travaux en Gironde</span>
      <h1 class="mt-3 text-4xl md:text-5xl font-black uppercase text-white">Réalisations</h1>
      <p class="mt-3 text-gray-300 max-w-xl mx-auto">
        Glissez le curseur sur chaque photo pour voir la transformation avant / après.
      </p>
    </div>
  </section>

  <!-- Filtres -->
  <section class="py-10 bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-wrap justify-center gap-3" role="group" aria-label="Filtrer par catégorie">
        {categories.map((cat) => (
          <button
            data-filter={cat}
            class:list={[
              "filter-btn font-bold uppercase tracking-wide text-sm px-6 py-2.5 border-2 transition-all duration-200",
              cat === "Tous"
                ? "border-gray-900 bg-gray-900 text-white"
                : "border-gray-200 text-gray-600 hover:border-gray-900 hover:text-gray-900"
            ]}
            aria-pressed={cat === "Tous" ? "true" : "false"}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Grille réalisations -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div id="realisations-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {realisations.map((r, i) => (
          <article
            data-categorie={r.categorie}
            data-reveal
            data-reveal-delay={String((i % 3) + 1)}
            class="realisation-item"
          >
            <div
              class="ba-slider relative overflow-hidden rounded-xl aspect-[4/3] cursor-ew-resize select-none"
              data-slider
            >
              <!-- AVANT (fond) -->
              <Image
                src={r.avant}
                alt={`Avant — ${r.titre} à ${r.lieu}`}
                width={600}
                height={450}
                class="absolute inset-0 w-full h-full object-cover"
                draggable="false"
              />

              <!-- APRÈS (clippée) -->
              <div class="ba-after absolute inset-0" style="clip-path: inset(0 50% 0 0);">
                <Image
                  src={r.apres}
                  alt={`Après — ${r.titre} à ${r.lieu}`}
                  width={600}
                  height={450}
                  class="w-full h-full object-cover"
                  draggable="false"
                />
              </div>

              <!-- Ligne blanche -->
              <div class="ba-divider absolute top-0 bottom-0 left-1/2 w-0.5 bg-white -translate-x-1/2 pointer-events-none"></div>

              <!-- Poignée -->
              <div class="ba-handle absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-11 h-11 rounded-full bg-white shadow-lg flex items-center justify-center pointer-events-none z-10">
                <svg class="w-5 h-5 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l-4 3 4 3M16 9l4 3-4 3" />
                </svg>
              </div>

              <!-- Labels -->
              <span class="absolute top-3 left-3 bg-black/60 text-white text-xs font-bold px-2.5 py-1 rounded-full pointer-events-none z-10">Avant</span>
              <span class="absolute top-3 right-3 bg-green-600/90 text-white text-xs font-bold px-2.5 py-1 rounded-full pointer-events-none z-10">Après</span>

              <!-- Badge catégorie -->
              <span class="absolute bottom-3 left-3 bg-white text-gray-800 text-xs font-bold uppercase px-3 py-1 rounded-full pointer-events-none z-10 shadow-sm">
                {r.categorie}
              </span>
            </div>

            <!-- Infos -->
            <div class="mt-4 px-1 flex items-start justify-between">
              <div>
                <p class="font-bold text-gray-900">{r.titre}</p>
                <p class="text-sm text-gray-500 mt-0.5">{r.lieu}, Gironde</p>
              </div>
              <a
                href={`/services/${r.categorie.toLowerCase().replace('é', 'e').replace('î', 'i').replace(' ', '-')}`}
                class="text-green-600 hover:text-green-700 text-xs font-bold uppercase tracking-wide hover:underline shrink-0 ml-4 mt-0.5"
                aria-label={`En savoir plus sur le service ${r.categorie}`}
              >
                Ce service →
              </a>
            </div>
          </article>
        ))}
      </div>

      <!-- Message aucun résultat -->
      <p id="no-results" class="hidden text-center text-gray-400 py-16 text-lg">
        Aucune réalisation dans cette catégorie pour le moment.
      </p>

    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-white text-center">
    <div class="max-w-3xl mx-auto px-6">
      <h2 data-reveal class="text-3xl md:text-4xl font-black uppercase text-gray-900 mb-4">
        Votre projet en Gironde ?
      </h2>
      <p data-reveal class="text-gray-500 text-lg mb-8">
        Contactez-nous pour discuter de votre projet et recevoir un devis gratuit sous 48h.
      </p>
      <a
        data-reveal
        href="/contact"
        class="inline-flex items-center gap-3 bg-green-600 hover:bg-green-700 text-white font-bold px-10 py-4 uppercase tracking-wide transition-all duration-200 hover:scale-105"
      >
        Demander un devis gratuit
      </a>
    </div>
  </section>

</BaseLayout>

<script>
  // Filtres
  const filterBtns = document.querySelectorAll('[data-filter]') as NodeListOf<HTMLButtonElement>;
  const items = document.querySelectorAll('.realisation-item') as NodeListOf<HTMLElement>;
  const noResults = document.getElementById('no-results');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.filter ?? 'Tous';

      // Mettre à jour les boutons
      filterBtns.forEach((b) => {
        b.classList.remove('border-gray-900', 'bg-gray-900', 'text-white');
        b.classList.add('border-gray-200', 'text-gray-600');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('border-gray-900', 'bg-gray-900', 'text-white');
      btn.classList.remove('border-gray-200', 'text-gray-600');
      btn.setAttribute('aria-pressed', 'true');

      // Filtrer les items avec animation
      let visible = 0;
      items.forEach((item) => {
        const match = cat === 'Tous' || item.dataset.categorie === cat;
        if (match) {
          item.style.display = '';
          visible++;
        } else {
          item.style.display = 'none';
        }
      });

      if (noResults) {
        noResults.classList.toggle('hidden', visible > 0);
      }
    });
  });

  // Sliders avant/après
  document.querySelectorAll('[data-slider]').forEach((slider) => {
    const after = slider.querySelector('.ba-after') as HTMLElement;
    const divider = slider.querySelector('.ba-divider') as HTMLElement;
    const handle = slider.querySelector('.ba-handle') as HTMLElement;
    let dragging = false;

    function setPos(clientX: number) {
      const rect = slider.getBoundingClientRect();
      const pct = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
      after.style.clipPath = `inset(0 ${Math.round((1 - pct) * 100)}% 0 0)`;
      divider.style.left = `${Math.round(pct * 100)}%`;
      handle.style.left = `${Math.round(pct * 100)}%`;
    }

    slider.addEventListener('mousedown', (e) => { e.preventDefault(); dragging = true; setPos((e as MouseEvent).clientX); });
    window.addEventListener('mousemove', (e) => { if (dragging) setPos((e as MouseEvent).clientX); });
    window.addEventListener('mouseup', () => { dragging = false; });

    slider.addEventListener('touchstart', (e) => { dragging = true; setPos((e as TouchEvent).touches[0].clientX); }, { passive: true });
    window.addEventListener('touchmove', (e) => { if (dragging) setPos((e as TouchEvent).touches[0].clientX); }, { passive: true });
    window.addEventListener('touchend', () => { dragging = false; });
  });
</script>
