---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { services } from "../../data/services";

export async function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<BaseLayout titre={service.seoTitle} description={service.seoDescription}>

  <!-- ═══════════════════════════════════════════════════════
       HERO — parallax + overlay
  ══════════════════════════════════════════════════════════ -->
  <section class="relative h-[85vh] min-h-[560px] flex items-center justify-center overflow-hidden">

    <div
      id="service-hero-bg"
      class="absolute inset-0 bg-cover bg-center will-change-transform scale-110"
      style={`background-image: url('${service.image}');`}
      aria-hidden="true"
    ></div>

    <!-- Overlay double couche -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/75 via-black/55 to-black/85" aria-hidden="true"></div>

    <!-- Ligne verte en bas du hero -->
    <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-green-500 to-transparent"></div>

    <div class="relative z-10 text-center text-white px-6 max-w-5xl mx-auto">

      <!-- Badge -->
      <p class="hero-badge inline-block text-green-400 font-bold uppercase tracking-widest text-sm mb-6 border border-green-400/30 px-5 py-2 rounded-full">
        {service.heroBadge} · Gironde
      </p>

      <!-- Titre -->
      <h1 class="hero-title text-5xl md:text-7xl font-black uppercase leading-[1.05] mb-7">
        {service.title}
      </h1>

      <!-- Intro -->
      <p class="hero-sub text-xl md:text-2xl text-gray-200 max-w-2xl mx-auto mb-10 leading-relaxed">
        {service.intro}
      </p>

      <!-- CTAs -->
      <div class="hero-ctas flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="group inline-flex items-center justify-center gap-3 bg-green-600 text-white font-bold px-9 py-4 uppercase tracking-wide hover:bg-green-500 transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-green-600/30"
        >
          <svg class="w-5 h-5 shrink-0 transition-transform group-hover:rotate-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
          Contactez-nous
        </a>
        <a
          href="tel:+33700000000"
          class="inline-flex items-center justify-center gap-3 border-2 border-white/60 text-white font-bold px-9 py-4 uppercase tracking-wide hover:bg-white hover:text-gray-900 transition-all duration-300"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          07 00 00 00 00
        </a>
      </div>

    </div>

    <!-- Flèche bas -->
    <div class="hero-arrow absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 text-white/50 text-xs">
      <svg class="w-6 h-6 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </div>

  </section>

  <!-- ═══════════════════════════════════════════════════════
       SECTION 1 — Expertise + engagements
  ══════════════════════════════════════════════════════════ -->
  <section class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">

      <div class="grid lg:grid-cols-5 gap-16 items-start">

        <!-- Texte (3/5) -->
        <div class="lg:col-span-3">
          <p data-reveal class="text-green-600 font-bold uppercase tracking-widest text-sm mb-3">
            Notre expertise
          </p>
          <h2 data-reveal class="text-4xl md:text-5xl font-black uppercase text-gray-900 mb-3 leading-tight">
            Votre spécialiste<br/>
            <span class="text-green-600">en Gironde</span>
          </h2>
          <div data-reveal class="w-14 h-1 bg-green-600 mb-10"></div>

          <div class="space-y-6 text-lg text-gray-600 leading-relaxed">
            <p data-reveal>{service.content.section1}</p>
            <p data-reveal data-reveal-delay="1">{service.content.section2}</p>
            <p data-reveal data-reveal-delay="2">{service.content.section3}</p>
          </div>

          <div data-reveal data-reveal-delay="3" class="mt-10">
            <a
              href="/contact"
              class="inline-flex items-center gap-3 bg-green-600 text-white font-bold px-8 py-4 uppercase tracking-wide hover:bg-green-700 transition-all duration-200 hover:scale-105"
            >
              Obtenir mon devis gratuit
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Engagements (2/5) -->
        <div class="lg:col-span-2 space-y-4">
          {[
            { icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z", titre: "Devis gratuit sous 48h", texte: "Sans engagement, visite sur site incluse" },
            { icon: "M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z", titre: "Toute la Gironde", texte: "Bordeaux, Arcachon, Libourne et +30 communes" },
            { icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z", titre: "Particuliers & professionnels", texte: "Résidences, copropriétés, entreprises" },
            { icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z", titre: "Intervention rapide", texte: "Délais respectés, travail soigné garanti" },
          ].map((item, i) => (
            <div
              data-reveal
              data-reveal-delay={String(i + 1)}
              class="flex items-start gap-4 p-5 border border-gray-100 hover:border-green-200 hover:bg-green-50/50 transition-all duration-200 group"
            >
              <div class="w-10 h-10 rounded-xl bg-green-100 group-hover:bg-green-600 flex items-center justify-center shrink-0 transition-colors duration-200">
                <svg class="w-5 h-5 text-green-600 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
                </svg>
              </div>
              <div>
                <p class="font-bold text-gray-900 text-sm">{item.titre}</p>
                <p class="text-gray-500 text-xs mt-0.5">{item.texte}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       SECTION 2 — Prestations (fond vert foncé)
  ══════════════════════════════════════════════════════════ -->
  <section class="py-24 bg-gray-900 relative overflow-hidden">

    <!-- Texture de fond -->
    <div class="absolute inset-0 opacity-5" style="background-image: url('data:image/svg+xml,%3Csvg width=\'30\' height=\'30\' viewBox=\'0 0 30 30\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Ccircle cx=\'3\' cy=\'3\' r=\'1\'/%3E%3C/g%3E%3C/svg%3E');"></div>

    <!-- Accent -->
    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-green-500 to-transparent"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-6">

      <div data-reveal class="text-center mb-16">
        <p class="text-green-400 font-bold uppercase tracking-widest text-sm mb-3">Ce que nous réalisons</p>
        <h2 class="text-4xl md:text-5xl font-black uppercase text-white">
          Nos prestations
        </h2>
        <div class="w-14 h-1 bg-green-600 mx-auto mt-5"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {service.benefits.map((benefit, i) => (
          <div
            data-reveal
            data-reveal-delay={String((i % 3) + 1)}
            class="group flex items-center gap-4 bg-white/5 hover:bg-green-600/20 border border-white/10 hover:border-green-500/50 p-5 transition-all duration-300 hover:-translate-y-0.5"
          >
            <div class="w-10 h-10 rounded-full bg-green-600 flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <span class="text-white font-semibold">{benefit}</span>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       SECTION 3 — Processus (timeline)
  ══════════════════════════════════════════════════════════ -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">

      <div data-reveal class="text-center mb-16">
        <p class="text-green-600 font-bold uppercase tracking-widest text-sm mb-3">Comment ça se passe ?</p>
        <h2 class="text-4xl md:text-5xl font-black uppercase text-gray-900">
          Notre méthode
        </h2>
        <div class="section-divider"></div>
      </div>

      <!-- Timeline desktop -->
      <div class="relative">

        <!-- Ligne de connexion (desktop) -->
        <div class="hidden md:block absolute top-8 left-[10%] right-[10%] h-0.5 bg-green-200 z-0"></div>

        <div class="grid grid-cols-1 md:grid-cols-5 gap-8 relative z-10">
          {service.process.map((step, i) => (
            <div
              data-reveal
              data-reveal-delay={String(i + 1)}
              class="flex flex-col items-center text-center group"
            >
              <!-- Cercle numéroté -->
              <div class="w-16 h-16 rounded-full bg-white border-2 border-green-200 group-hover:border-green-600 group-hover:bg-green-600 flex items-center justify-center text-xl font-black text-green-600 group-hover:text-white transition-all duration-300 shadow-sm mb-5">
                {i + 1}
              </div>
              <p class="font-bold text-gray-900 text-sm uppercase tracking-wide">{step}</p>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       SECTION 4 — FAQ accordion interactif
  ══════════════════════════════════════════════════════════ -->
  <section class="py-24 bg-white">
    <div class="max-w-4xl mx-auto px-6">

      <div data-reveal class="text-center mb-16">
        <p class="text-green-600 font-bold uppercase tracking-widest text-sm mb-3">Vous avez des questions ?</p>
        <h2 class="text-4xl md:text-5xl font-black uppercase text-gray-900">
          FAQ
        </h2>
        <div class="section-divider"></div>
      </div>

      <div class="space-y-3" id="faq-list">
        {service.faq.map((item, i) => (
          <div
            data-reveal
            data-reveal-delay={String(i + 1)}
            class="faq-item border border-gray-200 overflow-hidden"
            data-faq
          >
            <button
              class="faq-btn w-full flex items-center justify-between gap-4 px-6 py-5 text-left hover:bg-gray-50 transition-colors duration-200"
              aria-expanded="false"
            >
              <span class="font-bold text-gray-900 text-base">{item.question}</span>
              <svg
                class="faq-icon w-5 h-5 text-green-600 shrink-0 transition-transform duration-300"
                fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-answer overflow-hidden max-h-0 transition-all duration-300 ease-in-out">
              <p class="px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-100 pt-4">
                {item.answer}
              </p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       SECTION 5 — CTA final
  ══════════════════════════════════════════════════════════ -->
  <section class="py-28 bg-gray-950 text-white relative overflow-hidden">

    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-green-500 to-transparent"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">

      <p data-reveal class="text-green-400 font-bold uppercase tracking-widest text-sm mb-6">
        Prêt à démarrer ?
      </p>

      <h2 data-reveal class="text-4xl md:text-6xl font-black uppercase leading-tight mb-6">
        Besoin d'un<br/>
        <span class="text-green-400">devis gratuit ?</span>
      </h2>

      <p data-reveal class="text-gray-300 text-xl max-w-xl mx-auto mb-12 leading-relaxed">
        Réponse sous 48h, visite sur site incluse.<br/>
        Intervention sur Bordeaux et toute la Gironde.
      </p>

      <div data-reveal class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="group inline-flex items-center justify-center gap-3 bg-green-600 hover:bg-green-500 text-white font-bold px-10 py-4 uppercase tracking-wide transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-green-600/25"
        >
          <svg class="w-5 h-5 transition-transform group-hover:rotate-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
          Demander un devis
        </a>
        <a
          href="tel:+33700000000"
          class="group inline-flex items-center justify-center gap-3 border-2 border-white/40 hover:border-white text-white font-bold px-10 py-4 uppercase tracking-wide transition-all duration-300 hover:bg-white hover:text-gray-900"
        >
          <svg class="w-5 h-5 transition-transform group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          07 00 00 00 00
        </a>
      </div>

      <!-- Breadcrumb retour services -->
      <div data-reveal class="mt-12 pt-8 border-t border-white/10">
        <a href="/services" class="inline-flex items-center gap-2 text-gray-400 hover:text-green-400 text-sm transition-colors duration-200">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Voir tous nos services
        </a>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  // ── Parallax hero ─────────────────────────────────────────
  const heroBg = document.getElementById('service-hero-bg');
  if (heroBg) {
    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      if (scrollY <= window.innerHeight) {
        heroBg.style.transform = `scale(1.1) translateY(${scrollY * 0.25}px)`;
      }
    }, { passive: true });
  }

  // ── FAQ accordion ─────────────────────────────────────────
  document.querySelectorAll('[data-faq]').forEach((item) => {
    const btn = item.querySelector<HTMLElement>('.faq-btn');
    const answer = item.querySelector<HTMLElement>('.faq-answer');
    const icon = item.querySelector<SVGElement>('.faq-icon');

    if (!btn || !answer) return;

    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      // Fermer tous les autres
      document.querySelectorAll('[data-faq]').forEach((other) => {
        const otherBtn = other.querySelector<HTMLElement>('.faq-btn');
        const otherAnswer = other.querySelector<HTMLElement>('.faq-answer');
        const otherIcon = other.querySelector<SVGElement>('.faq-icon');
        if (otherBtn && otherAnswer && other !== item) {
          otherBtn.setAttribute('aria-expanded', 'false');
          otherAnswer.style.maxHeight = '0';
          if (otherIcon) otherIcon.style.transform = 'rotate(0deg)';
        }
      });

      // Toggle courant
      if (isOpen) {
        btn.setAttribute('aria-expanded', 'false');
        answer.style.maxHeight = '0';
        if (icon) icon.style.transform = 'rotate(0deg)';
      } else {
        btn.setAttribute('aria-expanded', 'true');
        answer.style.maxHeight = answer.scrollHeight + 'px';
        if (icon) icon.style.transform = 'rotate(180deg)';
      }
    });
  });
</script>
