---
---

<section class="relative h-screen min-h-[600px] flex items-center justify-center overflow-hidden">

  <!-- Image de fond avec effet parallax JS -->
  <div
    id="hero-bg"
    class="absolute inset-0 bg-cover bg-center bg-no-repeat will-change-transform scale-110"
    style="background-image: url('/images/hero-bg.jpg');"
    aria-hidden="true"
  ></div>

  <!-- Overlay dégradé -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/55 to-black/75" aria-hidden="true"></div>

  <!-- Contenu -->
  <div class="relative z-10 text-center text-white px-6 max-w-5xl mx-auto">

    <p class="hero-badge inline-block text-green-400 font-bold uppercase tracking-widest text-sm mb-5 border border-green-400/30 px-4 py-1.5 rounded-full">
      Paysagiste en Gironde · Bordeaux &amp; toute la région
    </p>

    <h1 class="hero-title text-5xl md:text-7xl font-black uppercase leading-[1.05] mb-7">
      Transformez votre<br/>
      <span class="text-green-400 relative">
        espace extérieur
        <svg class="absolute -bottom-2 left-0 w-full h-2 text-green-600/40" viewBox="0 0 400 8" fill="none" preserveAspectRatio="none" aria-hidden="true">
          <path d="M0 6 Q100 2 200 6 Q300 10 400 4" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/>
        </svg>
      </span>
    </h1>

    <p class="hero-sub text-lg md:text-xl text-gray-200 max-w-2xl mx-auto mb-10 leading-relaxed">
      Création, aménagement et entretien de jardins en Gironde.
      Un savoir-faire professionnel au service de vos espaces verts.
    </p>

    <div class="hero-ctas flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/contact"
        class="group inline-flex items-center justify-center gap-3 bg-green-600 text-white font-bold px-9 py-4 uppercase tracking-wide hover:bg-green-500 transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-green-600/30"
      >
        <svg class="w-5 h-5 shrink-0 transition-transform group-hover:rotate-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
        Demander un devis gratuit
      </a>
      <a
        href="/realisations"
        class="inline-flex items-center justify-center gap-2 border-2 border-white/70 text-white font-bold px-9 py-4 uppercase tracking-wide hover:bg-white hover:text-gray-900 transition-all duration-300"
      >
        Voir nos réalisations
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>

    <!-- Garanties rapides -->
    <div class="hero-ctas mt-12 flex flex-wrap justify-center gap-6 text-sm text-gray-300">
      {[
        "✓ Devis gratuit sous 48h",
        "✓ Intervention sur toute la Gironde",
        "✓ Particuliers & professionnels",
      ].map((item) => (
        <span>{item}</span>
      ))}
    </div>

  </div>

  <!-- Flèche scroll animée -->
  <div class="hero-arrow absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 animate-bounce">
    <span class="text-white/50 text-xs uppercase tracking-widest">Découvrir</span>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white/70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </div>

</section>

<script>
  const heroBg = document.getElementById('hero-bg');
  if (heroBg) {
    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      const maxScroll = window.innerHeight;
      if (scrollY <= maxScroll) {
        heroBg.style.transform = `scale(1.1) translateY(${scrollY * 0.25}px)`;
      }
    }, { passive: true });
  }
</script>
