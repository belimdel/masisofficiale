---
---

<section class="relative py-28 bg-gray-950 overflow-hidden">

  <!-- Motif de fond décoratif -->
  <div class="absolute inset-0 opacity-5" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

  <!-- Accent vert en haut -->
  <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-green-500 to-transparent"></div>

  <!-- Orbes flottants décoratifs (parallax desktop) -->
  <div id="cta-orb-1" class="absolute top-12 left-[8%] w-56 h-56 rounded-full bg-green-500/5 blur-3xl pointer-events-none" aria-hidden="true"></div>
  <div id="cta-orb-2" class="absolute bottom-12 right-[8%] w-72 h-72 rounded-full bg-green-600/5 blur-3xl pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">

    <span
      data-reveal
      class="inline-block text-green-400 font-bold uppercase tracking-widest text-sm mb-6"
    >
      Prêt à démarrer votre projet ?
    </span>

    <h2
      data-reveal
      class="text-4xl md:text-6xl font-black uppercase text-white leading-tight mb-6"
    >
      Transformez votre<br/>
      <span class="text-green-400">espace extérieur</span>
    </h2>

    <p
      data-reveal
      class="text-gray-300 text-lg md:text-xl max-w-2xl mx-auto mb-12 leading-relaxed"
    >
      Devis gratuit sous 48h. Intervention rapide sur Bordeaux Métropole
      et toute la Gironde. Particuliers et professionnels.
    </p>

    <div data-reveal class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/contact"
        class="group inline-flex items-center justify-center gap-3 bg-green-600 hover:bg-green-500 text-white font-bold px-10 py-4 uppercase tracking-wide transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-green-600/25 tap-target active:scale-95 ripple-container"
      >
        <svg class="w-5 h-5 transition-transform group-hover:rotate-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
        Demander un devis gratuit
      </a>
      <a
        href="tel:+33700000000"
        class="group inline-flex items-center justify-center gap-3 border-2 border-white/40 hover:border-white text-white font-bold px-10 py-4 uppercase tracking-wide transition-all duration-300 hover:bg-white hover:text-gray-900 tap-target active:scale-95"
      >
        <svg class="w-5 h-5 transition-transform group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        07 00 00 00 00
      </a>
    </div>

    <!-- Garanties sous les CTAs -->
    <div data-reveal class="flex flex-wrap justify-center gap-8 mt-10">
      {[
        { icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z", text: "Devis gratuit & sans engagement" },
        { icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z", text: "Réponse sous 48h" },
        { icon: "M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z", text: "Toute la Gironde" },
      ].map((item) => (
        <div class="flex items-center gap-2 text-gray-400 text-sm">
          <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
          </svg>
          <span>{item.text}</span>
        </div>
      ))}
    </div>

  </div>

</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const isTouch = window.matchMedia('(hover: none)').matches;

  if (!isTouch) {
    gsap.to('#cta-orb-1', {
      yPercent: -30,
      ease: 'none',
      scrollTrigger: {
        trigger: '#cta-orb-1',
        start: 'top bottom',
        end: 'bottom top',
        scrub: 1.5,
      },
    });
    gsap.to('#cta-orb-2', {
      yPercent: 20,
      ease: 'none',
      scrollTrigger: {
        trigger: '#cta-orb-2',
        start: 'top bottom',
        end: 'bottom top',
        scrub: 2,
      },
    });
  }
</script>
